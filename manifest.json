{
  "manifest_version": 3,
  "name": "Privacy Shield - Hide & Blur Sensitive Info",
  "version": "1.0.1",
  "description": "Instantly blur balances, text, emails, API keys, and custom elements on any website to protect your privacy.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield-16.png",
      "48": "icons/shield-48.png",
      "128": "icons/shield-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-blur": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Toggle Privacy Shield on the current page"
    }
  },
  "icons": {
    "16": "icons/shield-16.png",
    "48": "icons/shield-48.png",
    "128": "icons/shield-128.png"
  }
}